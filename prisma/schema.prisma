// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategorizationSource {
  MANUAL
  RULE
  IMPORT
  AI
}

model Transaction {
  id          String          @id @default(cuid())
  date        DateTime
  merchant    String
  description String
  amount      Decimal
  type        TransactionType
  category    String          @default("Needs Review")
  needsReview Boolean         @default(true)
  confidenceScore Float?
  categorizationSource CategorizationSource @default(IMPORT)
  aiSuggestedCategory String?
  aiReasoning String?
  reviewedAt   DateTime?
  accountName String
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([type])
  @@index([category])
  @@index([needsReview])
  @@index([reviewedAt])
}

model CategoryRule {
  id              String          @id @default(cuid())
  matchText        String
  category         String
  transactionType  TransactionType? // null = applies to both
  priority         Int             @default(100)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([priority])
  @@index([transactionType])
}

model AppSettings {
  id String @id @default("singleton")

  aiEnabled Boolean @default(false)
  ollamaModel String @default("llama3.2")
  aiConfidenceThreshold Float @default(0.85)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
