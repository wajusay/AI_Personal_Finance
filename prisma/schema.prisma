// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategorizationSource {
  MANUAL
  RULE
  IMPORT
  AI
}

enum EntityType {
  PERSONAL
  LLC
  TRUST
  FOUNDATION
  BUSINESS
  PROPERTY
}

enum DocumentationStatus {
  UNKNOWN
  NOT_NEEDED
  NEEDED
  UPLOADED
  MISSING
}

enum AuditRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum StatementParsingStatus {
  PENDING
  PARSED
  FAILED
}

enum StatementVerificationStatus {
  PENDING
  PASSED
  FAILED
  OVERRIDDEN
}

model Transaction {
  id          String          @id @default(cuid())
  date        DateTime
  merchant    String
  description String
  amount      Decimal
  type        TransactionType
  category    String          @default("Needs Review")
  needsReview Boolean         @default(true)
  confidenceScore Float?
  categorizationSource CategorizationSource @default(IMPORT)
  aiSuggestedCategory String?
  aiReasoning String?
  reviewedAt   DateTime?
  entityId    String?
  entity      Entity?         @relation(fields: [entityId], references: [id])
  taxCategoryId String?
  taxCategory TaxCategory?    @relation(fields: [taxCategoryId], references: [id])
  businessPurpose String?
  deductiblePercentage Int?   // 0..100
  documentationStatus DocumentationStatus @default(UNKNOWN)
  accountName String
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([type])
  @@index([category])
  @@index([needsReview])
  @@index([reviewedAt])
  @@index([entityId])
  @@index([taxCategoryId])
}

model CategoryRule {
  id              String          @id @default(cuid())
  matchText        String
  category         String
  transactionType  TransactionType? // null = applies to both
  priority         Int             @default(100)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([priority])
  @@index([transactionType])
}

model AppSettings {
  id String @id @default("singleton")

  aiEnabled Boolean @default(false)
  ollamaModel String @default("llama3.2")
  aiConfidenceThreshold Float @default(0.85)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Entity {
  id String @id @default(cuid())
  name String
  type EntityType @default(PERSONAL)
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@index([type])
}

model TaxCategory {
  id String @id @default(cuid())
  name String
  schedule String?
  lineItem String?
  description String?
  requiresDocumentation Boolean @default(false)
  auditRiskLevel AuditRiskLevel @default(MEDIUM)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@index([auditRiskLevel])
}

model Statement {
  id String @id @default(cuid())

  institutionName String
  accountName String
  statementStartDate DateTime
  statementEndDate DateTime
  openingBalance Decimal
  closingBalance Decimal
  uploadedFileName String
  parsingStatus StatementParsingStatus @default(PENDING)
  verificationStatus StatementVerificationStatus @default(PENDING)
  verificationDifference Decimal? // closing - (opening + sum)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statementStartDate])
  @@index([statementEndDate])
  @@index([parsingStatus])
  @@index([verificationStatus])
}
